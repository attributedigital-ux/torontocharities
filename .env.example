# Database — Neon serverless Postgres
# Create a project at neon.tech, copy the connection string (it includes user, password, host, db)
DATABASE_URL="postgresql://user:password@host.neon.tech/torontocharities?sslmode=require"

# Anthropic API — for the two Claude pipelines (CRA descriptions + event enrichment)
# Both use Haiku 4.5. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth (Auth.js v5)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Resend — magic-link emails
# Get a key at resend.com (free tier: 3,000 emails/month, 100/day)
RESEND_API_KEY="re_..."
# Sender address must be on a domain verified in Resend (or use the onboarding@resend.dev for dev)
RESEND_FROM_EMAIL="noreply@toronto-charities.ca"

# Eventbrite — only needed for the VPS worker (Phase 3), not the web app
# eventbrite.com/platform/api → Account settings → API keys → Personal OAuth token
EVENTBRITE_TOKEN=""

# Plausible — public domain identifier (no secret needed for tracking pixel)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="toronto-charities.ca"
